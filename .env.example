# Environment variables example
# Copy this file to .env and fill in your own values

# Database Connection
# Transaction Pooler (port 6543) - for queries in app
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true"
# Session Pooler (port 5432) - for migrations and Prisma CLI
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key_here

# Session secret for signed auth cookies (required in production)
SESSION_SECRET=replace_with_a_long_random_secret

# Gemini AI API Keys (3 keys for load balancing)
GEMINI_API_KEY_1=your_gemini_api_key_1
GEMINI_API_KEY_2=your_gemini_api_key_2
GEMINI_API_KEY_3=your_gemini_api_key_3

# Web Push (optional — for push notifications)
VAPID_EMAIL=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
